@model List<Collection>

@{
    ViewData["Title"] = "Home Page";
}

<a class="btn btn-primary"
   style="margin:20px; width:300px;"
   asp-controller="Home"
   asp-action="ViewAll">
    Показать все книги
</a>

<div style="display:flex; flex-direction:row; margin:20px;">
    <form>

        <p>Укажите для поиска что-либо из следующих элементов:</p>

        <input placeholder="Название" name="Name" />
        <input placeholder="Автор" name="Author" />
        <input placeholder="Жанр" name="Genre" />
        <input placeholder="Краткое описание" name="Description" />

        <p style="margin-top:10px;">Оценки:</p>

        <input type="number" placeholder="От" name="from" />
        <input type="number" placeholder="До" name="to" />

        <button type="submit"
                asp-controller="Home"
                asp-action="Search">
            Найти
        </button>

    </form>
</div>

<div style="padding:30px;">

    @foreach (Collection item in Model)
    {
        <div style="margin-bottom:60px;">

            <h2 style="margin-bottom:30px; font-weight:700; font-size:32px;">
                @item.Name
            </h2>

            @{
                var books = item.Books.OrderByDescending(b => b.Rating).ToList();
            }

            <div style="display:flex; flex-wrap:wrap; gap:30px;">

                @foreach (var book in books)
                {
                    <a asp-controller="Book"
                       asp-action="Index"
                       asp-route-id="@book.Id"
                       style="text-decoration:none;">

                        <div class="book-card"
                             style="position:relative; width:220px; height:320px; overflow:hidden; border-radius:20px; box-shadow:0 5px 20px rgba(0,0,0,0.25); transition:0.3s; cursor:pointer;">

                            <img src="@book.PathImage"
                                 style="width:100%; height:100%; object-fit:cover;" />

                            <div class="book-info"
                                 style="position:absolute; bottom:0; left:0; width:100%; padding:20px; background:linear-gradient(to top, rgba(0,0,0,0.9), rgba(0,0,0,0)); color:white; opacity:0; transition:0.3s;">

                                <h4 style="margin:0; font-size:22px; font-weight:700;">
                                    @book.Name
                                </h4>

                                <p style="margin-top:5px; font-size:16px;">
                                    @book.Author
                                </p>

                            </div>

                        </div>

                    </a>
                }

            </div>
        </div>
    }

</div>